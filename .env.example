# PII Redacta Environment Configuration
# Copy this file to .env and update with your values

# Server
PII_REDACTA_SERVER_HOST=0.0.0.0
PII_REDACTA_SERVER_PORT=8080

# Database
PII_REDACTA_DATABASE_URL=postgres://pii_redacta:pii_redacta_dev@localhost:5432/pii_redacta_dev
PII_REDACTA_DATABASE_MAX_CONNECTIONS=10

# Redis
PII_REDACTA_REDIS_URL=redis://127.0.0.1:6379

# Security (generate with: openssl rand -base64 32)
PII_REDACTA_JWT_SECRET=change-me-to-a-secure-secret-at-least-32-bytes
PII_REDACTA_API_KEY_SECRET=change-me-base64-encoded-32-byte-secret-here

# Logging
RUST_LOG=info,pii_redacta_api=debug
