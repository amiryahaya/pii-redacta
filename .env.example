# PII Redacta Environment Configuration
# Copy this file to .env and update with your values

# Database
DATABASE_URL=postgres://postgres:postgres@localhost/pii_redacta_dev

# Redis
REDIS_URL=redis://127.0.0.1:6379

# API Key Secret (generate with: openssl rand -base64 32)
API_KEY_SECRET=your-super-secret-32-byte-key-here-change-me

# Session Secret (generate with: openssl rand -base64 32)
SESSION_SECRET=your-session-secret-32-byte-key-here-change-me

# Server Configuration
PORT=8080
HOST=0.0.0.0
RUST_LOG=info

# Optional: Stripe (for billing)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
